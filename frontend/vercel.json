{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "images": {
    "sizes": [256, 384, 512, 640, 750, 828, 1080, 1200, 1920, 2048],
    "domains": ["res.cloudinary.com", "hostelkart-backend.onrender.com"],
    "minimumCacheTTL": 86400,
    "formats": ["image/avif", "image/webp"]
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hostelkart-backend.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://hostelkart-backend.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}
